import java.lang.String;\par
class main\{\par
    public static void main(String[] args)\{\par
        Scanner obj = new Scanner(System.in);\par
        System.out.println("Enter a number between 0-5 : ");\par
        int number = obj.nextInt();\par
\par
        switch(number)\{\par
            case 0:\par
                System.out.println("The number is 0");\par
                break;\par
            case 1:\par
                System.out.println("The number is 1");\par
                break;\par
            case 2:\par
                System.out.println("The number is 2");\par
                break;    \par
            case 3:\par
                System.out.println("The number is 3");\par
                break;\par
            case 4:\par
                System.out.println("The number is 4");\par
                break;\par
            case 5:\par
                System.out.println("The number is 5");\par
                break;\par
            default:\par
                System.out.println("The number is neither Greater than 5 or less than 0");\par
                break;\par
