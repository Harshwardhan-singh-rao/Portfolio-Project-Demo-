Q) abstract class\par
import java.util.Scanner;\par
import java.lang.String;\par
abstract class Shape\{  //abstract class\par
abstract double area();  //abstract method\par
\}\par
class Circle extends Shape\{\par
double radius;\par
public Circle(double radius)\{\par
this.radius = radius;\par
\}\par
double area()\{\par
return Math.PI*radius*radius;\par
\}\par
\}\par
class main\{\par
public static void main(String[] args)\{\par
Scanner obj = new Scanner(System.in);\par
System.out.println("Enter the radius of the circle: ");\par
double radius = obj.nextDouble();\par
Circle cr = new Circle(radius);\par
System.out.println("The area of the circle with radius  " + radius + " is : " + cr.area()); \par
\}\par
\}\par
